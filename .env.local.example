NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
ANTHROPIC_API_KEY=your_anthropic_api_key
APIFY_TOKEN=your_apify_token
INSTANTLY_WEBHOOK_SECRET=your_instantly_webhook_secret
CREDENTIALS_ENCRYPTION_KEY=your_credentials_encryption_key

# --- Stripe ---
# Get from https://dashboard.stripe.com/test/apikeys (test mode first).
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# From `stripe listen --forward-to localhost:3000/api/webhooks/stripe` (locally)
# or the webhook endpoint detail page in the Stripe dashboard (deployed).
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — populated by `npx ts-node scripts/setup-stripe-products.ts`.
# That script creates Products + Prices in your Stripe account (idempotent)
# and prints the env block to paste here.
STRIPE_PRICE_STARTER_ONBOARDING=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_GROWTH_ONBOARDING=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_PRO_ONBOARDING=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_WHALE_ONBOARDING=
STRIPE_PRICE_WHALE_MONTHLY=
STRIPE_PRICE_WHALE_ANNUAL=
